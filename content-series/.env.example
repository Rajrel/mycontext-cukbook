# Copy this file to `.env` in this folder and fill in keys.
# Never commit `.env` with real secrets.

# Which provider mycontext uses for LLM calls in the notebooks:
# openai | anthropic | gemini
MC_SERIES_PROVIDER=openai

# --- At least one provider (match MC_SERIES_PROVIDER) ---
# Create a key at https://platform.openai.com/api-keys — do not put real keys in this file.
OPENAI_API_KEY=

ANTHROPIC_API_KEY=
# Gemini / Google (LiteLLM accepts either name)
GOOGLE_API_KEY=
# GEMINI_API_KEY=
